# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Facebook API Configuration
# Get these from: https://developers.facebook.com/
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_access_token_here

# Facebook Ad Account Configuration
# Find your Ad Account ID in Facebook Ads Manager (format: act_123456789)
FACEBOOK_AD_ACCOUNT_ID=your_ad_account_id_here

# Facebook Page Configuration
# Find your Page ID in your Facebook Page settings
FACEBOOK_PAGE_ID=your_page_id_here

# Note: Copy this file to .env and fill in your actual values
# The variable names MUST match exactly what's in os.getenv('VARIABLE_NAME') in the code





